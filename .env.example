# ═══════════════════════════════════════════════════════════════
# Consulta API SRI - Configuración
# ═══════════════════════════════════════════════════════════════

# Puerto del servidor (default: 3000)
PORT=3000

# Ambiente del SRI: 'pruebas' o 'produccion'
SRI_ENV=produccion

# Cantidad máxima de peticiones concurrentes al SRI
MAX_CONCURRENT=10

# Delay entre lotes de peticiones (en milisegundos)
DELAY_MS=0

# ═══════════════════════════════════════════════════════════════
# Google Drive CDN - Configuración con Service Account
# ═══════════════════════════════════════════════════════════════
# Todos los usuarios descargan desde Google Drive automáticamente
# Solo UN servidor (Master) sube a Drive cada 15 días

# Activar Google Drive CDN (todos los servidores)
GOOGLE_DRIVE_ENABLED=true

# Ruta al archivo JSON del Service Account (descargado de Google Cloud)
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=service-account.json

# ID de la carpeta en Google Drive (compartida con el Service Account)
GOOGLE_DRIVE_FOLDER_ID=TU_FOLDER_ID_AQUI

# Solo UN servidor debe ser Master (sube a Drive cada 15 días)
# Los demás servidores son usuarios (descargan desde Drive)
GOOGLE_DRIVE_MASTER=false

# ═══════════════════════════════════════════════════════════════
# Configuración de Catastros
# ═══════════════════════════════════════════════════════════════

# Cada cuántos días se actualizan los catastros (default: 15)
CATASTRO_ACTUALIZACION_DIAS=15

# Activar/desactivar el scheduler de descargas automáticas
CATASTRO_SCHEDULER=true
